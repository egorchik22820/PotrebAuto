<Window x:Class="PotrebAuto.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PotrebAuto.Windows"
        mc:Ignorable="d"
        Title="SettingsWindow" Height="450" Width="800">

    <Window.Resources>
        <Style x:Key="ValidatedTextBoxStyle" TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="Background" Value="LightCoral"/>
                    <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Label Content="Проставьте номера столбцов (или строк) для загружаемых файлов" HorizontalAlignment="Right" Margin="40,0" FontSize="12" FontWeight="SemiBold" Foreground="#FF0087FF"/>
        <TabControl Background="#FFDDEED0" Margin="0,3">
            <!-- Вкладка MP -->
            <TabItem Header="МП">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#FFDDEED0">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>



                        <Label Grid.Row="0" Grid.Column="0" Content="Признак ОДПУ:" Margin="0,5"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="MPIsODPUTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="Системный код прибора учёта:" Margin="0,5"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="MPSysPU_IdTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Адрес объекта ЭБ:" Margin="0,5"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="MPAddressTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="3" Grid.Column="0" Content="Qрасч.:" Margin="0,5"/>
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="MPQ_CalcTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="4" Grid.Column="0" Content="dVрасч.:" Margin="0,5"/>
                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="MPdV_CalcTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="5" Grid.Column="0" Content="ВНРрасч., ч:" Margin="0,5"/>
                        <TextBox Grid.Row="5" Grid.Column="1" x:Name="MPVNR_CalcTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="6" Grid.Column="0" Content="Вид нагрузки ЭБ:" Margin="0,5"/>
                        <TextBox Grid.Row="6" Grid.Column="1" x:Name="MPLoadTypeTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="7" Grid.Column="0" Content="Код строения:" Margin="0,5"/>
                        <TextBox Grid.Row="7" Grid.Column="1" x:Name="MPBuildingIdTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="8" Grid.Column="0" Content="ИД ТУ АИИС:" Margin="0,5"/>
                        <TextBox Grid.Row="8" Grid.Column="1" x:Name="MPTU_AIIS_IdTextBox" Margin="5" Height="25"/>

                        <Button Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                            FontWeight="SemiBold"
                            x:Name="MPSaveButton" Content="Сохранить настройки МП" 
                            Width="160" Height="30" Margin="0,10" HorizontalAlignment="Right"
                            Click="MPSaveButton_Click"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка Naklad -->
            <TabItem Header="Накладная">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#FFDDEED0">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Классификатор договора:" Margin="0,5"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="NakladDocTypeTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="Номенклатура:" Margin="0,5"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="NakladNomenclatureTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Тариф:" Margin="0,5"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="NakladTariffTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="3" Grid.Column="0" Content="Договорной метод расчета:" Margin="0,5"/>
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="NakladCalcTypeTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="4" Grid.Column="0" Content="Номенклатура.Единица:" Margin="0,5"/>
                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="NakladNomenclatureUnitTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="5" Grid.Column="0" Content="Количество:" Margin="0,5"/>
                        <TextBox Grid.Row="5" Grid.Column="1" x:Name="NakladQuantityTotalTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="6" Grid.Column="0" Content="Теплоисточник:" Margin="0,5"/>
                        <TextBox Grid.Row="6" Grid.Column="1" x:Name="NakladHeatSourseTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="7" Grid.Column="0" Content="Год перерасчета:" Margin="0,5"/>
                        <TextBox Grid.Row="7" Grid.Column="1" x:Name="NakladRecalcYearTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="8" Grid.Column="0" Content="Вид нагрузки:" Margin="0,5"/>
                        <TextBox Grid.Row="8" Grid.Column="1" x:Name="NakladLoadTypeTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="9" Grid.Column="0" Content="Подразделение:" Margin="0,5"/>
                        <TextBox Grid.Row="9" Grid.Column="1" x:Name="NakladDepartmentTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="10" Grid.Column="0" Content="Адрес теплоустановки:" Margin="0,5"/>
                        <TextBox Grid.Row="10" Grid.Column="1" x:Name="NakladAddressTUTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="11" Grid.Column="0" Content="Код строения:" Margin="0,5"/>
                        <TextBox Grid.Row="11" Grid.Column="1" x:Name="NakladBuildingIdTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="12" Grid.Column="0" Content="Строение(тоже адрес, только короче):" Margin="0,5"/>
                        <TextBox Grid.Row="12" Grid.Column="1" x:Name="NakladBuildingAddressTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="13" Grid.Column="0" Content="Тип здания:" Margin="0,5"/>
                        <TextBox Grid.Row="13" Grid.Column="1" x:Name="NakladBuildingTypeTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="14" Grid.Column="0" Content="Вид помещения:" Margin="0,5"/>
                        <TextBox Grid.Row="14" Grid.Column="1" x:Name="NakladSpaceTypeTextBox" Margin="5" Height="25"/>

                        <StackPanel Grid.Row="15" Grid.Column="0" HorizontalAlignment="Center" Grid.ColumnSpan="2">
                            <Label Content="Проставьте год (только год, не дату!), к которому относится накладная." Margin="0,0" FontSize="14" FontWeight="SemiBold" Foreground="#FFD76704"/>
                            <Label Content="(Например, если накладная от 15.10.25, то нужно написать 2025)" Margin="0,0" FontSize="14" FontWeight="SemiBold" Foreground="#FFD76704" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <Label Grid.Row="16" Grid.Column="0" Content="Год(значение):" Margin="0,5"/>
                        <TextBox Grid.Row="16" Grid.Column="1" x:Name="NakladCalcYearValueTextBox" Margin="5" Height="25"/>

                        <Button Grid.Row="17" Grid.Column="0" Grid.ColumnSpan="2"
                            FontWeight="SemiBold"
                            x:Name="NakladSaveButton" Content="Сохранить настройки накладной" 
                            Width="200" Height="30" Margin="0,10" HorizontalAlignment="Right"
                            Click="NakladSaveButton_Click"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка ODN -->
            <TabItem Header="ОДН">
                <Grid Margin="10" Background="#FFDDEED0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Строение, код:" Margin="0,5"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="ODNBuildingIdTextBox" Margin="5" Height="25"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="Отрицательный ОДН на Конец периода, Гкал:" Margin="0,5"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="ODNNegativeODN_GcalTextBox" Margin="5" Height="25"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="Отрицательный ОДН на Конец периода, м3:" Margin="0,5"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="ODNNegativeODN_m3TextBox" Margin="5" Height="25"/>

                    <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                        FontWeight="SemiBold"
                        x:Name="ODNSaveButton" Content="Сохранить настройки ОДН" 
                        Width="170" Height="30" Margin="0,10" HorizontalAlignment="Right"
                        Click="ODNSaveButton_Click"/>
                </Grid>
            </TabItem>

            <!-- Вкладка PoteryGVS -->
            <TabItem Header="Потери ГВС">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- With ODPU Section -->
                        <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Content="МКД с ОДПУ" FontWeight="Bold" Margin="0,10"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="Код строения:" Margin="0,5"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="WithODPUBuildingIdTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Город:" Margin="0,5"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="WithODPUCityTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="3" Grid.Column="0" Content="Зона теплоснабжения:" Margin="0,5"/>
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="WithODPUHeatSupplyZoneTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="4" Grid.Column="0" Content="ЦТП:" Margin="0,5"/>
                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="WithODPUZTPTextBox" Margin="5" Height="25"/>

                        <!-- Without ODPU Section -->
                        <Label Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Content="МКД без ОДПУ" FontWeight="Bold" Margin="0,10"/>

                        <Label Grid.Row="6" Grid.Column="0" Content="Код строения:" Margin="0,5"/>
                        <TextBox Grid.Row="6" Grid.Column="1" x:Name="WithoutODPUBuildingIdTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="7" Grid.Column="0" Content="Город:" Margin="0,5"/>
                        <TextBox Grid.Row="7" Grid.Column="1" x:Name="WithoutODPUCityTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="8" Grid.Column="0" Content="Зона теплоснабжения:" Margin="0,5"/>
                        <TextBox Grid.Row="8" Grid.Column="1" x:Name="WithoutODPUHeatSupplyZoneTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="9" Grid.Column="0" Content="Тип здания:" Margin="0,5"/>
                        <TextBox Grid.Row="9" Grid.Column="1" x:Name="WithoutODPUBuildingTypeTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="10" Grid.Column="0" Content="ЦТП:" Margin="0,5"/>
                        <TextBox Grid.Row="10" Grid.Column="1" x:Name="WithoutODPUZTPTextBox" Margin="5" Height="25"/>

                        <!-- With ITP Section -->
                        <Label Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2" Content="МКД с ИТП" FontWeight="Bold" Margin="0,10"/>

                        <Label Grid.Row="12" Grid.Column="0" Content="Код строения:" Margin="0,5"/>
                        <TextBox Grid.Row="12" Grid.Column="1" x:Name="WithITPBuildingIdTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="13" Grid.Column="0" Content="Город:" Margin="0,5"/>
                        <TextBox Grid.Row="13" Grid.Column="1" x:Name="WithITPCityTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="14" Grid.Column="0" Content="Зона теплоснабжения:" Margin="0,5"/>
                        <TextBox Grid.Row="14" Grid.Column="1" x:Name="WithITPHeatSupplyZoneTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="15" Grid.Column="0" Content="Способ расчета:" Margin="0,5"/>
                        <!--remove-->
                        <TextBox Grid.Row="15" Grid.Column="1" x:Name="WithITPCalcTypeTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="16" Grid.Column="0" Content="Тип здания:" Margin="0,5"/>
                        <TextBox Grid.Row="16" Grid.Column="1" x:Name="WithITPBuildingTypeTextBox" Margin="5" Height="25"/>

                        <Label Grid.Row="17" Grid.Column="0" Content="ЦТП:" Margin="0,5"/>
                        <TextBox Grid.Row="17" Grid.Column="1" x:Name="WithITPZTPTextBox" Margin="5" Height="25"/>


                        <Button Grid.Row="19" Grid.Column="0" Grid.ColumnSpan="2"
                            FontWeight="SemiBold"
                            x:Name="PoteryGVSSaveButton" Content="Сохранить настройки потерь ГВС" 
                            Width="220" Height="30" Margin="0,10" HorizontalAlignment="Right"
                            Click="PoteryGVSSaveButton_Click"/>



                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка начальные строки -->
            <TabItem Header="Начальные строки">
                <Grid Margin="10" Background="#FFDDEED0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" Grid.ColumnSpan="2">
                        <Label Content="Проставьте необходимые номера строк закгружаемых файлов, с которых начинаеются данные" Margin="0,0" FontSize="14" FontWeight="SemiBold" Foreground="#FFD76704"/>
                        <Label Content="(не там, где начинаются заголовки столбцов, а там, где уже сами данные)" Margin="0,0" FontSize="14" FontWeight="SemiBold" Foreground="#FFD76704" HorizontalAlignment="Center"/>
                    </StackPanel>


                    <Label Grid.Row="1" Grid.Column="0" Content="МП файл:" Margin="0,5"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="MP_StartRowTextBox" Margin="5" Height="25"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="Накладная:" Margin="0,5"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="Naklad_StartRowTextBox" Margin="5" Height="25"/>

                    <Label Grid.Row="3" Grid.Column="0" Content="ОДН файл:" Margin="0,5"/>
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="ODN_StartRowTextBox" Margin="5" Height="25"/>

                    <Label Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Content="Файл потерь ГВС:" FontWeight="Bold" Margin="10,10"/>

                    <Label Grid.Row="5" Grid.Column="0" Content="МКД с ОДПУ:" Margin="0,5"/>
                    <TextBox Grid.Row="5" Grid.Column="1" x:Name="WithODPU_StartRowTextBox" Margin="5" Height="25"/>

                    <Label Grid.Row="6" Grid.Column="0" Content="МКД без ОДПУ:" Margin="0,5"/>
                    <TextBox Grid.Row="6" Grid.Column="1" x:Name="WithOutODPU_StartRowTextBox" Margin="5" Height="25"/>

                    <Label Grid.Row="7" Grid.Column="0" Content="МКД с ИТП:" Margin="0,5"/>
                    <TextBox Grid.Row="7" Grid.Column="1" x:Name="WithITP_StartRowTextBox" Margin="5" Height="25"/>

                    <Button Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                        FontWeight="SemiBold"
                        x:Name="ODNSaveButаton" Content="Сохранить настройки строк" 
                        Width="175" Height="30" Margin="0,10" HorizontalAlignment="Right"
                        Click="SatrtRowsSaveButton_Click"/>

                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
