<Window x:Class="PotrebAuto.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PotrebAuto.Windows"
        mc:Ignorable="d"
        Title="SettingsWindow" Height="450" Width="800">

    <Window.Resources>
        <Style x:Key="ValidatedTextBoxStyle" TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="Background" Value="LightCoral"/>
                    <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Label Content="Проставьте номера столбцов (или строк) для загружаемых файлов" HorizontalAlignment="Right" Margin="40,0" FontSize="12" FontWeight="SemiBold" Foreground="#FF0087FF"/>
        <TabControl Background="#FFDDEED0" Margin="0,3">
            
            <!-- Вкладка Исходник -->
            <TabItem Header="Source">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#FFDDEED0">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Number:" Margin="0,5"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="NumberTextBox" Margin="5" Height="25" TextChanged="NumberTextBox_TextChanged"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="Address:" Margin="0,5"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="AddressTextBox" Margin="5" Height="25" TextChanged="AddressTextBox_TextChanged"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="TU AIIS:" Margin="0,5"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="TU_AIISTextBox" Margin="5" Height="25" TextChanged="TU_AIISTextBox_TextChanged"/>

                        <Label Grid.Row="3" Grid.Column="0" Content="Object ID:" Margin="0,5"/>
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="ObjectIdTextBox" Margin="5" Height="25" TextChanged="ObjectIdTextBox_TextChanged"/>

                        <Label Grid.Row="4" Grid.Column="0" Content="PO AIIS Total:" Margin="0,5"/>
                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="PO_AIIS_TotalTextBox" Margin="5" Height="25" TextChanged="PO_AIIS_TotalTextBox_TextChanged"/>

                        <Label Grid.Row="5" Grid.Column="0" Content="Color Days Count:" Margin="0,5"/>
                        <TextBox Grid.Row="5" Grid.Column="1" x:Name="ColorDaysCountTextBox" Margin="5" Height="25" TextChanged="ColorDaysCountTextBox_TextChanged"/>

                        <Label Grid.Row="6" Grid.Column="0" Content="ID:" Margin="0,5"/>
                        <TextBox Grid.Row="6" Grid.Column="1" x:Name="IdTextBox" Margin="5" Height="25" TextChanged="IdTextBox_TextChanged"/>

                        <Label Grid.Row="7" Grid.Column="0" Content="PU Gcal Total:" Margin="0,5"/>
                        <TextBox Grid.Row="7" Grid.Column="1" x:Name="PU_GcalTotalTextBox" Margin="5" Height="25" TextChanged="PU_GcalTotalTextBox_TextChanged"/>

                        <Label Grid.Row="8" Grid.Column="0" Content="PU With VNR Gcal:" Margin="0,5"/>
                        <TextBox Grid.Row="8" Grid.Column="1" x:Name="PU_WithVNR_GcalTextBox" Margin="5" Height="25" TextChanged="PU_WithVNR_GcalTextBox_TextChanged"/>

                        <Label Grid.Row="9" Grid.Column="0" Content="ZM Gcal Total:" Margin="0,5"/>
                        <TextBox Grid.Row="9" Grid.Column="1" x:Name="ZM_GcalTotalTextBox" Margin="5" Height="25" TextChanged="ZM_GcalTotalTextBox_TextChanged"/>

                        <Label Grid.Row="10" Grid.Column="0" Content="ZM With Average Gcal:" Margin="0,5"/>
                        <TextBox Grid.Row="10" Grid.Column="1" x:Name="ZM_WithAverage_GcalTextBox" Margin="5" Height="25" TextChanged="ZM_WithAverage_GcalTextBox_TextChanged"/>

                        <Label Grid.Row="11" Grid.Column="0" Content="With BS Gcal:" Margin="0,5"/>
                        <TextBox Grid.Row="11" Grid.Column="1" x:Name="WithBS_GcalTextBox" Margin="5" Height="25" TextChanged="WithBS_GcalTextBox_TextChanged"/>

                        <Label Grid.Row="12" Grid.Column="0" Content="With Real Load BS Gcal:" Margin="0,5"/>
                        <TextBox Grid.Row="12" Grid.Column="1" x:Name="WithRealLoadBS_GcalTextBox" Margin="5" Height="25" TextChanged="WithRealLoadBS_GcalTextBox_TextChanged"/>

                        <Label Grid.Row="13" Grid.Column="0" Content="With Real Load TU Gcal:" Margin="0,5"/>
                        <TextBox Grid.Row="13" Grid.Column="1" x:Name="WithRealLoadTU_GcalTextBox" Margin="5" Height="25" TextChanged="WithRealLoadTU_GcalTextBox_TextChanged"/>

                        <Label Grid.Row="14" Grid.Column="0" Content="With NP Gcal:" Margin="0,5"/>
                        <TextBox Grid.Row="14" Grid.Column="1" x:Name="WithNP_GcalTextBox" Margin="5" Height="25" TextChanged="WithNP_GcalTextBox_TextChanged"/>

                        <Label Grid.Row="15" Grid.Column="0" Content="With Cab Gcal:" Margin="0,5"/>
                        <TextBox Grid.Row="15" Grid.Column="1" x:Name="WithCab_GcalTextBox" Margin="5" Height="25" TextChanged="WithCab_GcalTextBox_TextChanged"/>

                        <Label Grid.Row="16" Grid.Column="0" Content="With KSN Gcal:" Margin="0,5"/>
                        <TextBox Grid.Row="16" Grid.Column="1" x:Name="WithKSN_GcalTextBox" Margin="5" Height="25" TextChanged="WithKSN_GcalTextBox_TextChanged"/>

                        <Label Grid.Row="17" Grid.Column="0" Content="With Real Load FN Gcal:" Margin="0,5"/>
                        <TextBox Grid.Row="17" Grid.Column="1" x:Name="WithRealLoad_FN_GcalTextBox" Margin="5" Height="25" TextChanged="WithRealLoad_FN_GcalTextBox_TextChanged"/>

                        <Label Grid.Row="18" Grid.Column="0" Content="With Doc And KSN Gcal:" Margin="0,5"/>
                        <TextBox Grid.Row="18" Grid.Column="1" x:Name="WithDocAndKSN_GcalTextBox" Margin="5" Height="25" TextChanged="WithDocAndKSN_GcalTextBox_TextChanged"/>

                        <Label Grid.Row="19" Grid.Column="0" Content="With Doc Gcal:" Margin="0,5"/>
                        <TextBox Grid.Row="19" Grid.Column="1" x:Name="WithDoc_GcalTextBox" Margin="5" Height="25" TextChanged="WithDoc_GcalTextBox_TextChanged"/>

                        <Label Grid.Row="20" Grid.Column="0" Content="Correct Notes Count:" Margin="0,5"/>
                        <TextBox Grid.Row="20" Grid.Column="1" x:Name="CorrectNotesCountTextBox" Margin="5" Height="25" TextChanged="CorrectNotesCountTextBox_TextChanged"/>

                        <Label Grid.Row="21" Grid.Column="0" Content="Q T M Is Null:" Margin="0,5"/>
                        <TextBox Grid.Row="21" Grid.Column="1" x:Name="Q_T_M_IsNullTextBox" Margin="5" Height="25" TextChanged="Q_T_M_IsNullTextBox_TextChanged"/>

                        <Label Grid.Row="22" Grid.Column="0" Content="Acts BS:" Margin="0,5"/>
                        <TextBox Grid.Row="22" Grid.Column="1" x:Name="ActsBSTextBox" Margin="5" Height="25" TextChanged="ActsBSTextBox_TextChanged"/>

                        <Label Grid.Row="23" Grid.Column="0" Content="Max Min Q M:" Margin="0,5"/>
                        <TextBox Grid.Row="23" Grid.Column="1" x:Name="Max_Min_Q_MTextBox" Margin="5" Height="25" TextChanged="Max_Min_Q_MTextBox_TextChanged"/>

                        <Label Grid.Row="24" Grid.Column="0" Content="Is Valid VNR:" Margin="0,5"/>
                        <TextBox Grid.Row="24" Grid.Column="1" x:Name="IsValid_VNRTextBox" Margin="5" Height="25" TextChanged="IsValid_VNRTextBox_TextChanged"/>

                        <Label Grid.Row="25" Grid.Column="0" Content="Is Valid M1 M2:" Margin="0,5"/>
                        <TextBox Grid.Row="25" Grid.Column="1" x:Name="IsValid_M1_M2TextBox" Margin="5" Height="25" TextChanged="IsValid_M1_M2TextBox_TextChanged"/>

                        <Label Grid.Row="26" Grid.Column="0" Content="Is Valid M1 M2 2:" Margin="0,5"/>
                        <TextBox Grid.Row="26" Grid.Column="1" x:Name="IsValid_M1_M2_2TextBox" Margin="5" Height="25" TextChanged="IsValid_M1_M2_2TextBox_TextChanged"/>

                        <Label Grid.Row="27" Grid.Column="0" Content="Q Eng:" Margin="0,5"/>
                        <TextBox Grid.Row="27" Grid.Column="1" x:Name="Q_engTextBox" Margin="5" Height="25" TextChanged="Q_engTextBox_TextChanged"/>

                        <Label Grid.Row="28" Grid.Column="0" Content="Is Valid T:" Margin="0,5"/>
                        <TextBox Grid.Row="28" Grid.Column="1" x:Name="IsValid_TTextBox" Margin="5" Height="25" TextChanged="IsValid_TTextBox_TextChanged"/>

                        <Button Grid.Row="29" Grid.Column="0" Grid.ColumnSpan="2"
                FontWeight="SemiBold"
                x:Name="SaveConsumerButton" Content="Save Consumer Data" 
                Width="160" Height="30" Margin="0,10" HorizontalAlignment="Right"
                Click="SaveConsumerButton_Click"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка Источники - потребители -->
            <TabItem Header="SourcesAndConsumers">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#FFDDEED0">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="TU ID:" Margin="0,5"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TU_IdTextBox" Margin="5" Height="25" TextChanged="TU_IdTextBox_TextChanged"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="Object ID:" Margin="0,5"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="Obj_IdTextBox" Margin="5" Height="25" TextChanged="Obj_IdTextBox_TextChanged"/>

                        <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                FontWeight="SemiBold"
                x:Name="SaveSourcesConsumersButton" Content="Save Sources and Consumers" 
                Width="200" Height="30" Margin="0,10" HorizontalAlignment="Right"
                Click="SaveSourcesConsumersButton_Click"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>


            <!-- Вкладка начальные строки -->
            <TabItem Header="Начальные строки">
                <Grid Margin="10" Background="#FFDDEED0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" Grid.ColumnSpan="2">
                        <Label Content="Проставьте необходимые номера строк закгружаемых файлов, с которых начинаеются данные" Margin="0,0" FontSize="14" FontWeight="SemiBold" Foreground="#FFD76704"/>
                        <Label Content="(не там, где начинаются заголовки столбцов, а там, где уже сами данные)" Margin="0,0" FontSize="14" FontWeight="SemiBold" Foreground="#FFD76704" HorizontalAlignment="Center"/>
                    </StackPanel>


                    <Label Grid.Row="1" Grid.Column="0" Content="МП файл:" Margin="0,5"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="MP_StartRowTextBox" Margin="5" Height="25"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="Накладная:" Margin="0,5"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="Naklad_StartRowTextBox" Margin="5" Height="25"/>

                    <Label Grid.Row="3" Grid.Column="0" Content="ОДН файл:" Margin="0,5"/>
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="ODN_StartRowTextBox" Margin="5" Height="25"/>

                    <Label Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Content="Файл потерь ГВС:" FontWeight="Bold" Margin="10,10"/>

                    <Label Grid.Row="5" Grid.Column="0" Content="МКД с ОДПУ:" Margin="0,5"/>
                    <TextBox Grid.Row="5" Grid.Column="1" x:Name="WithODPU_StartRowTextBox" Margin="5" Height="25"/>

                    <Label Grid.Row="6" Grid.Column="0" Content="МКД без ОДПУ:" Margin="0,5"/>
                    <TextBox Grid.Row="6" Grid.Column="1" x:Name="WithOutODPU_StartRowTextBox" Margin="5" Height="25"/>

                    <Label Grid.Row="7" Grid.Column="0" Content="МКД с ИТП:" Margin="0,5"/>
                    <TextBox Grid.Row="7" Grid.Column="1" x:Name="WithITP_StartRowTextBox" Margin="5" Height="25"/>

                    <Button Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                        FontWeight="SemiBold"
                        x:Name="ODNSaveButаton" Content="Сохранить настройки строк" 
                        Width="175" Height="30" Margin="0,10" HorizontalAlignment="Right"
                        Click="SatrtRowsSaveButton_Click"/>

                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
